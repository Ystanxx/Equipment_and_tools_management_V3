DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/equipment_mgmt
SECRET_KEY=change-me-to-a-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=480
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=admin
SUPER_ADMIN_EMAIL=admin@example.com
UPLOAD_DIR=./uploads

# SMTP 邮件通知配置；Outlook/Hotmail 通常使用 587 + STARTTLS
SMTP_HOST=smtp-mail.outlook.com
SMTP_PORT=587
SMTP_USER=your-notify-account@outlook.com
SMTP_PASSWORD=your-app-password-or-mailbox-password
SMTP_USE_SSL=false
SMTP_FROM_NAME=器材管理系统
SMTP_FROM_EMAIL=your-notify-account@outlook.com
